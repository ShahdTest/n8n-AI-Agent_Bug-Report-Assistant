      "parameters": {
        "jsCode": "const items = $input.all();\n\nfunction extract(text, header) {\n  if (!text) return '';\n  const regex = new RegExp('(?:\\\\*\\\\*)?' + header + ':(?:\\\\*\\\\*)?\\\\s*([\\\\s\\\\S]*?)(?=\\\\n(?:\\\\*\\\\*)?[\\\\w\\\\s]+:|$)','i');\n  const match = text.match(regex);\n  return match ? match[1].trim() : '';\n}\n\nreturn items.map(item => {\n  const output = item.json.output || item.json.ai_report || '';\n  const files = item.json.files || [];\n  \n  return {\n    json: {\n      output: output,\n      title: extract(output, 'Title'),\n      severity: extract(output, 'Severity'),\n      priority: extract(output, 'Priority'),\n      summary: extract(output, 'Summary'),\n      steps: extract(output, 'Steps to Reproduce'),\n      expected_result: extract(output, 'Expected Result'),\n      actual_result: extract(output, 'Actual Result'),\n      environment: extract(output, 'Environment'),\n      additional_info: extract(output, 'Additional Information'),\n      reproduction_frequency: extract(output, 'Reproduction Frequency'),\n      files: files\n    }\n  };\n});\n"
      },
