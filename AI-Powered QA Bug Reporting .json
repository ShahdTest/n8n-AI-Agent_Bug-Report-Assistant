      "parameters": {
        "jsCode": "const newBug = $('Report Parser').first().json;\nconst items = $input.all();\nconst searchResult = items.find(item => item.json.score !== undefined);\n\nif (!searchResult) {\n  return [{\n    json: {\n      isDuplicate: false,\n      newBug: newBug,\n      similarityScore: 0,\n      note: \"No similar bugs found.\"\n    }\n  }];\n}\n\nconst similarityScore = searchResult.json.score || 0;\nconst THRESHOLD = 0.85;\n\nreturn [{\n  json: {\n    isDuplicate: similarityScore >= THRESHOLD,\n    newBug: newBug,\n    similarityScore: similarityScore,\n    matchedBug: searchResult.json.metadata || searchResult.json\n  }\n}];\n"
      },
