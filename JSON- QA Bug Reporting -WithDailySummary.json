        "jsCode": "const jiraData = $json;\n\nconst ticketKey = jiraData.key;\nconst self = jiraData.self;\nconst issueId = jiraData.id;\n\n// Extract base URL dynamically\nconst baseURL = self.split('/rest')[0];\n\n// Build final Jira URL\nconst jiraURL = `${baseURL}/browse/${ticketKey}`;\n\nreturn [\n  {\n    json: {\n      ticketKey,\n      jiraURL,\n      issueId\n    }\n  }\n];"
