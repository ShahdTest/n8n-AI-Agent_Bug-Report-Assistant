    {
      "parameters": {
        "jsCode": "const items = $input.all();\n\n// Count bugs by severity\nconst severityCounts = {};\nconst priorityCounts = {};\nconst jiraIds = [];\n\nitems.forEach(item => {\n  const severity = item.json.Severity || \"Unknown\";\n  const priority = item.json.Priority || \"Unknown\";\n  const jiraId = item.json[\"Jira ID\"];\n  \n  severityCounts[severity] = (severityCounts[severity] || 0) + 1;\n  priorityCounts[priority] = (priorityCounts[priority] || 0) + 1;\n  \n  if (jiraId && jiraId.trim() !== \"\") {\n    jiraIds.push(jiraId.trim());\n  }\n});\n\nreturn [{\n  json: {\n    totalBugs: items.length,\n    jiraIds: jiraIds,\n    severityCounts: severityCounts,\n    priorityCounts: priorityCounts,\n    reportDate: new Date().toISOString().split(\"T\")[0]\n  }\n}];"
      },
      "id": "6b987bec-babd-4802-a510-1a96c139dc9b",
      "name": "Count Bugs by Status",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -2416,
        404
      ]
    },
    {
      "parameters": {
        "jsCode": "const data = $json;\n\n// Build severity table\nlet severityTable = \"| Severity | Count |\\n|----------|-------|\\n\";\nObject.entries(data.severityCounts).forEach(([severity, count]) => {\n  severityTable += `| ${severity} | ${count} |\\n`;\n});\n\n// Build priority table\nlet priorityTable = \"| Priority | Count |\\n|----------|-------|\\n\";\nObject.entries(data.priorityCounts).forEach(([priority, count]) => {\n  priorityTable += `| ${priority} | ${count} |\\n`;\n});\n\n// Build status table\nlet statusTable = \"| Status | Count |\\n|--------|-------|\\n\";\nstatusTable += `| With Jira ID | ${data.withJiraId} |\\n`;\nstatusTable += `| Without Jira ID | ${data.withoutJiraId} |\\n`;\n\nconst htmlReport = `\n<h2>Daily Bug Report - ${data.reportDate}</h2>\n<h3>Summary</h3>\n<p><strong>Total Bugs Reported:</strong> ${data.totalBugs}</p>\n\n<h3>Status Breakdown</h3>\n<table border=\"1\" cellpadding=\"5\" cellspacing=\"0\">\n  <tr><th>Status</th><th>Count</th></tr>\n  <tr><td>With Jira ID</td><td>${data.withJiraId}</td></tr>\n  <tr><td>Without Jira ID</td><td>${data.withoutJiraId}</td></tr>\n</table>\n\n<h3>Severity Breakdown</h3>\n<table border=\"1\" cellpadding=\"5\" cellspacing=\"0\">\n  <tr><th>Severity</th><th>Count</th></tr>\n  ${Object.entries(data.severityCounts).map(([sev, cnt]) => `<tr><td>${sev}</td><td>${cnt}</td></tr>`).join(\"\")}\n</table>\n\n<h3>Priority Breakdown</h3>\n<table border=\"1\" cellpadding=\"5\" cellspacing=\"0\">\n  <tr><th>Priority</th><th>Count</th></tr>\n  ${Object.entries(data.priorityCounts).map(([pri, cnt]) => `<tr><td>${pri}</td><td>${cnt}</td></tr>`).join(\"\")}\n</table>\n`;\n\nreturn [{\n  json: {\n    ...data,\n    severityTable: severityTable,\n    priorityTable: priorityTable,\n    statusTable: statusTable,\n    htmlReport: htmlReport\n  }\n}];"
      },
      "id": "f230514e-88c4-4691-ac43-5d5f2b683f3e",
      "name": "Format Report Table",
